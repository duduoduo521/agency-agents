# ============================================
# The Code Agency- 环境变量配置示例
# 
# 使用方法:
# 1. 复制此文件为 .env
# 2. 填入你的实际配置值
# 3. 重启服务器
# ============================================

# ============================================
# 钉钉机器人配置
# ============================================
# 是否启用钉钉通知 (true/false)
DINGTALK_ENABLED=false

# 钉钉 Webhook URL
# 获取方式：钉钉管理后台 -> 机器人 -> Webhook
DINGTALK_WEBHOOK=https://oapi.dingtalk.com/robot/send?access_token=YOUR_TOKEN

# 钉钉加签密钥（可选，用于签名验证）
DINGTALK_SECRET=SECXXXXXXXX

# ============================================
# 飞书机器人配置
# ============================================
# 是否启用飞书通知 (true/false)
FEISHU_ENABLED=false

# 飞书 Webhook URL
# 获取方式：飞书开放平台 -> 事件订阅 -> 请求地址配置
FEISHU_WEBHOOK=https://open.feishu.cn/open-apis/bot/v2/hook/YOUR_HOOK

# 飞书加密密钥（可选）
FEISHU_SECRET=XXXXXXXX

# ============================================
# Coding Plan 配置（阿里云百炼）
# ============================================
# 是否启用阿里云 Coding Plan (true/false)
ALI_ENABLED=true

# 阿里云百炼 API Key
# 获取方式：阿里云百炼控制台 -> API Key 管理
ALI_API_KEY=your-ali-api-key-here

# 阿里云百炼 API Endpoint
ALI_ENDPOINT=https://dashscope.aliyuncs.com/api/v1

# 阿里云通义千问 Coding Plan 套餐类型
# 可选值：qwen-coder-plus, qwen-coder-turbo, qwen2.5-coder-32b
ALI_PLAN_TYPE=qwen-coder-plus

# ============================================
# Coding Plan 配置（腾讯云混元）
# ============================================
# 是否启用腾讯云 Coding Plan (true/false)
TENCENT_ENABLED=false

# 腾讯云 SecretId
# 获取方式：腾讯云控制台 -> 访问管理 -> API 密钥管理
TENCENT_SECRET_ID=your-secret-id-here

# 腾讯云 SecretKey
TENCENT_SECRET_KEY=your-secret-key-here

# 腾讯云混元 API Endpoint
TENCENT_ENDPOINT=https://hunyuan.tencentcloudapi.com

# 腾讯云混元 Coding Plan 套餐类型
# 可选值：hunyuan-code-pro, hunyuan-code-lite
TENCENT_PLAN_TYPE=hunyuan-code-pro

# ============================================
# Coding Plan 配置（百度文心一言）
# ============================================
# 是否启用百度云 Coding Plan (true/false)
BAIDU_ENABLED=false

# 百度云千帆 API Key (Client ID)
# 获取方式：百度智能云千帆控制台 -> 应用接入
BAIDU_API_KEY=your-baidu-api-key-here

# 百度云千帆 Secret Key (Client Secret)
BAIDU_SECRET_KEY=your-baidu-secret-key-here

# 百度云千帆 API Endpoint
BAIDU_ENDPOINT=https://aip.baidubce.com/rpc/2.0/ai_custom/v1

# 百度文心一言 Coding Plan 套餐类型
# 可选值：ernie-bot-code-pro, ernie-bot-code-lite
BAIDU_PLAN_TYPE=ernie-bot-code-pro

# ============================================
# 服务器配置
# ============================================
PORT=3000
